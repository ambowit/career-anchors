# v0 Cloud Supabase Configuration
# Environment variables are automatically injected by v0 Supabase integration:
# - NEXT_PUBLIC_SUPABASE_URL
# - NEXT_PUBLIC_SUPABASE_ANON_KEY
# - SUPABASE_SERVICE_ROLE_KEY (server-side only)

# For Vite compatibility (maps to v0 integration env vars)
VITE_SUPABASE_URL=${NEXT_PUBLIC_SUPABASE_URL}
VITE_SUPABASE_PUBLISHABLE_KEY=${NEXT_PUBLIC_SUPABASE_ANON_KEY}

# OOOK AI Gateway Configuration (for Edge Functions)
# Note: These should be set in Supabase Edge Function secrets
OOOK_AI_GATEWAY_URL=https://gateway.oook.cn/
OOOK_AI_GATEWAY_TOKEN=your_oook_api_token_here
